{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "FastAPI: Dev Server",
      "type": "python",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "backend.main:app",
        "--reload",
        "--port", "8000",
        "--log-level", "debug"
      ],
      "env": {
        "PYTHONPATH": "${workspaceFolder}",
        "ENV_FILE": "${workspaceFolder}/.env"
      },
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}
