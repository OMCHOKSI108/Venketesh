APP_NAME=market-data-platform
DEBUG=false
LOG_LEVEL=INFO
ENVIRONMENT=development
API_V1_PREFIX=/api/v1

DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/marketdata
DATABASE_POOL_SIZE=20

REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=50
REDIS_OHLC_TTL_SECONDS=60

NSE_BASE_URL=https://www.nseindia.com
NSE_QUOTE_URL=https://www.nseindia.com/api/quote-equity
NSE_TIMEOUT_SECONDS=10.0

POLL_INTERVAL=2
WS_HEARTBEAT_INTERVAL=30

NSE_ENABLED=true
YAHOO_ENABLED=true
UPSTOX_ENABLED=false
UPSTOX_API_KEY=
UPSTOX_SECRET=
